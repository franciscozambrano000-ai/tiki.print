<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ticket GMF Cafetería</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Courier New', Courier, monospace;
      background: #e8e8e8;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 20px;
    }

    /* ── BOTÓN IMPRIMIR (solo visible en pantalla) ── */
    .print-bar {
      width: 100%;
      max-width: 340px;
      margin-bottom: 16px;
    }

    .btn-print {
      width: 100%;
      padding: 14px;
      background: #000;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: 'Courier New', monospace;
      font-size: 16px;
      font-weight: 900;
      letter-spacing: 3px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-print:active { background: #333; }

    /* ── TICKET ── */
    .ticket {
      width: 100%;
      max-width: 340px;
      background: #fff;
      border-radius: 4px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.18);
      overflow: hidden;
    }

    .ticket-header {
      background: #000;
      color: #fff;
      text-align: center;
      padding: 16px 12px 14px;
    }
    .ticket-header .marca { font-size: 11px; letter-spacing: 6px; opacity: 0.6; }
    .ticket-header .nombre { font-size: 26px; font-weight: 900; letter-spacing: 5px; line-height: 1; margin: 4px 0 2px; }
    .ticket-header .sub { font-size: 9px; letter-spacing: 3px; opacity: 0.5; }

    .beneficiario {
      padding: 14px 16px 12px;
      border-bottom: 3px solid #000;
    }
    .beneficiario .etiqueta { font-size: 9px; letter-spacing: 3px; color: #888; font-weight: 900; }
    .beneficiario .nombre-grande { font-size: 24px; font-weight: 900; line-height: 1.1; margin-top: 3px; }
    .beneficiario .grado-tag {
      display: inline-block;
      border: 2px solid #000;
      padding: 2px 10px;
      font-size: 13px;
      font-weight: 900;
      margin-top: 6px;
      letter-spacing: 1px;
    }

    .cuerpo { padding: 12px 16px; }

    .dia-bloque {
      text-align: center;
      margin-bottom: 10px;
    }
    .dia-nombre { font-size: 28px; font-weight: 900; letter-spacing: 3px; }
    .dia-fecha  { font-size: 12px; color: #666; font-weight: 700; }
    .pedido-id  { font-size: 9px; color: #aaa; letter-spacing: 1px; margin-top: 2px; }
    .cliente-ref { font-size: 10px; color: #888; margin-top: 1px; }

    .sep-solid  { border-top: 2px solid #000; margin: 10px 0; }
    .sep-dash   { border-top: 1px dashed #aaa; margin: 8px 0; }
    .sep-double { border-top: 3px double #000; margin: 12px 0; }

    .seccion-titulo {
      font-size: 9px;
      font-weight: 900;
      letter-spacing: 3px;
      color: #555;
      margin-bottom: 8px;
    }

    .plato-label { font-size: 9px; color: #aaa; letter-spacing: 1px; }
    .plato-nombre { font-size: 18px; font-weight: 900; line-height: 1.2; padding-left: 4px; margin-bottom: 4px; }

    .monto-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }
    .pago-info { font-size: 11px; color: #777; }
    .monto-bloque { text-align: right; }
    .monto-label { font-size: 9px; color: #aaa; letter-spacing: 1px; }
    .monto-valor { font-size: 32px; font-weight: 900; line-height: 1; }

    .estado-label {
      font-size: 9px;
      letter-spacing: 3px;
      color: #aaa;
      text-align: center;
      margin-bottom: 4px;
    }
    .estado-box {
      border: 3px solid #000;
      padding: 10px 6px;
      text-align: center;
      font-size: 13px;
      font-weight: 900;
      letter-spacing: 1px;
      margin-bottom: 12px;
    }

    .ticket-footer {
      border-top: 1px dashed #ccc;
      padding: 10px 0 4px;
      text-align: center;
    }
    .footer-tiki { font-size: 16px; font-weight: 900; letter-spacing: 8px; }
    .footer-sub  { font-size: 8px; color: #bbb; letter-spacing: 1px; margin-top: 2px; }

    /* ── PRINT STYLES ── */
    @media print {
      body {
        background: #fff;
        padding: 0;
        display: block;
      }
      .print-bar { display: none !important; }
      .ticket {
        max-width: 80mm;
        width: 80mm;
        box-shadow: none;
        border-radius: 0;
      }
      @page {
        size: 80mm auto;
        margin: 0;
      }
    }
  </style>
</head>
<body>

  <div class="print-bar">
    <button class="btn-print" onclick="imprimir()">🖨️ IMPRIMIR</button>
  </div>

  <div class="ticket">

    <div class="ticket-header">
      <div class="marca">GMF</div>
      <div class="nombre">CAFETERÍA</div>
      <div class="sub">SISTEMA TIKI · VIEW TECH</div>
    </div>

    <div class="beneficiario" id="bloque-beneficiario">
      <div class="etiqueta" id="etiqueta-beneficiario">CLIENTE</div>
      <div class="nombre-grande" id="nombre-principal">—</div>
      <div class="grado-tag" id="grado-tag" style="display:none"></div>
    </div>

    <div class="cuerpo">

      <div class="dia-bloque">
        <div class="dia-nombre" id="dia-nombre">—</div>
        <div class="dia-fecha"  id="dia-fecha">—</div>
        <div class="pedido-id"  id="pedido-id">—</div>
        <div class="cliente-ref" id="cliente-ref" style="display:none"></div>
      </div>

      <div class="sep-solid"></div>
      <div class="seccion-titulo">▸ PEDIDO</div>

      <!-- Menú Estudiantil -->
      <div id="bloque-estudiantil" style="display:none">
        <div class="plato-label">MENÚ ESTUDIANTIL</div>
        <div class="plato-nombre" id="plato-estudiantil"></div>
      </div>

      <!-- Menú Ejecutivo -->
      <div id="bloque-ejecutivo" style="display:none">
        <div style="margin-bottom:8px; padding-left:4px">
          <div class="plato-label">ENTRADA</div>
          <div class="plato-nombre" id="plato-entrada"></div>
        </div>
        <div class="sep-dash"></div>
        <div style="padding-left:4px">
          <div class="plato-label">SEGUNDO</div>
          <div class="plato-nombre" id="plato-segundo"></div>
        </div>
      </div>

      <div class="sep-double"></div>

      <div class="monto-row">
        <div class="pago-info">
          <div class="plato-label">MÉTODO DE PAGO</div>
          <div id="metodo-pago" style="font-weight:900; font-size:13px;">—</div>
        </div>
        <div class="monto-bloque">
          <div class="monto-label">TOTAL DEL DÍA</div>
          <div class="monto-valor" id="monto">S/0.00</div>
        </div>
      </div>

      <div class="sep-double"></div>

      <div class="estado-label">ESTADO</div>
      <div class="estado-box" id="estado">—</div>

      <div class="ticket-footer">
        <div class="footer-tiki">TIKI</div>
        <div class="footer-sub" id="footer-fecha">VIEW TECH</div>
      </div>

    </div>
  </div>

<script>
  // ── LEER PARÁMETROS DE LA URL ──────────────────────────
  function getParam(name) {
    var url = new URLSearchParams(window.location.search);
    return decodeURIComponent(url.get(name) || '');
  }

  var pedidoId      = getParam('pedidoId');
  var cliente       = getParam('cliente');
  var beneficiario  = getParam('beneficiario');
  var grado         = getParam('grado');
  var dia           = getParam('dia');
  var fecha         = getParam('fecha');
  var estudiantil   = getParam('estudiantil');
  var entrada       = getParam('entrada');
  var segundo       = getParam('segundo');
  var monto         = getParam('monto');
  var metodoPago    = getParam('metodoPago');
  var estado        = getParam('estado');

  // ── RELLENAR TICKET ───────────────────────────────────

  // Beneficiario o cliente
  var tieneAlumno = beneficiario && beneficiario !== '' && beneficiario !== 'Para mí';
  if (tieneAlumno) {
    document.getElementById('etiqueta-beneficiario').textContent = 'ALUMNO';
    document.getElementById('nombre-principal').textContent = beneficiario;
    if (grado) {
      var gt = document.getElementById('grado-tag');
      gt.textContent = grado;
      gt.style.display = 'inline-block';
    }
    var cr = document.getElementById('cliente-ref');
    cr.textContent = 'Cliente: ' + cliente;
    cr.style.display = 'block';
  } else {
    document.getElementById('etiqueta-beneficiario').textContent = 'CLIENTE';
    document.getElementById('nombre-principal').textContent = cliente || '—';
  }

  // Día y fecha
  var diaCapital = dia ? dia.charAt(0).toUpperCase() + dia.slice(1).toLowerCase() : '—';
  document.getElementById('dia-nombre').textContent = diaCapital.toUpperCase();
  document.getElementById('dia-fecha').textContent  = fecha || '—';
  document.getElementById('pedido-id').textContent  = pedidoId || '—';

  // Platos
  if (estudiantil) {
    document.getElementById('bloque-estudiantil').style.display = 'block';
    document.getElementById('plato-estudiantil').textContent = estudiantil;
  } else {
    document.getElementById('bloque-ejecutivo').style.display = 'block';
    document.getElementById('plato-entrada').textContent = entrada || '—';
    document.getElementById('plato-segundo').textContent = segundo || '—';
  }

  // Monto
  var montoNum = parseFloat(monto) || 0;
  document.getElementById('monto').textContent = 'S/' + montoNum.toFixed(2);

  // Método de pago
  var metodos = { 'yape': 'Yape', 'transferencia': 'Transferencia', '': 'Efectivo' };
  document.getElementById('metodo-pago').textContent = metodos[metodoPago] || metodoPago || 'Efectivo';

  // Estado
  document.getElementById('estado').textContent = estado || '🟡 PENDIENTE';

  // Footer fecha
  var ahora = new Date();
  var fechaGen = ahora.toLocaleDateString('es-PE') + ' ' + ahora.toLocaleTimeString('es-PE', {hour:'2-digit',minute:'2-digit'});
  document.getElementById('footer-fecha').textContent = 'VIEW TECH · ' + fechaGen;

  // ── IMPRESIÓN ─────────────────────────────────────────
  var isAndroid = /Android/i.test(navigator.userAgent);
  var isIOS     = /iPhone|iPad/i.test(navigator.userAgent);

  function imprimir() {
    window.print();
  }

  window.onload = function() {
    if (!isAndroid && !isIOS) {
      // Desktop: auto-print
      setTimeout(function() { window.print(); }, 800);
    }
    // Android/iOS: el usuario toca el botón
  };
</script>

</body>
</html>
